# ─────────────────────────────────────────────────────────────────────────────
# SecureBank AI — Streamlit Secrets Template
#
# FOR LOCAL DEV:
#   Copy this to .streamlit/secrets.toml and fill in real values.
#   (secrets.toml is in .gitignore — never committed)
#
# FOR STREAMLIT COMMUNITY CLOUD:
#   Paste these key=value pairs into the Secrets box in the Streamlit Cloud UI.
#   Do NOT upload this file — use the web UI secrets manager instead.
# ─────────────────────────────────────────────────────────────────────────────

# Demo password shown on the login screen
APP_PASSWORD = "securebank2025"

# AWS credentials — create a dedicated IAM user with BedrockInvoke + no other perms
# See: AWS Console → IAM → Users → Create user → Attach policy → AmazonBedrockFullAccess
AWS_ACCESS_KEY_ID     = "AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_DEFAULT_REGION    = "us-east-1"
BEDROCK_REGION        = "us-east-1"

# Bedrock model IDs (defaults shown — only change if you switch models)
LLM_MODEL   = "us.amazon.nova-lite-v1:0"
EMBED_MODEL = "amazon.titan-embed-text-v2:0"

# ClickHouse Cloud credentials
CLICKHOUSE_HOST     = "your-instance.ap-southeast-2.aws.clickhouse.cloud"
CLICKHOUSE_USER     = "default"
CLICKHOUSE_PASSWORD = "your-clickhouse-password"
